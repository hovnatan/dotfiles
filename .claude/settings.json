{
  "permissions": {
    "allow": [
      "Bash(git log *)",
      "Bash(git -C * log *)",
      "Bash(git status *)",
      "Bash(git -C * status *)",
      "Bash(git diff *)",
      "Bash(git -C * diff *)",
      "Bash(git show *)",
      "Bash(git -C * show *)",
      "Bash(tmux list-*)",
      "Bash(tmux show-*)",
      "Bash(tmux display-message *)",
      "Bash(tmux capture-pane *)",
      "Bash(tmux info *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo rm -rf *)",
      "Bash(git push --force *main*)",
      "Bash(git push --force *master*)",
      "Bash(git push -f *main*)",
      "Bash(git push -f *master*)",
      "Bash(git push --force *develop*)",
      "Bash(git push -f *develop*)",
      "Bash(dd if=* of=/dev/*)",
      "Bash(mkfs*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .*)",
      "Bash(git restore .*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm publish*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh issue close*)",
      "Bash(gh release create*)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-7[1m]",
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "multica-ai/andrej-karpathy-skills"
      }
    }
  },
  "effortLevel": "max",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/.claude/hooks/skill-notify.sh"
          }
        ]
      }
    ]
  }
}
