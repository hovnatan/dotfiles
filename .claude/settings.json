{
  "permissions": {
    "allow": [
      "Bash(git log *)",
      "Bash(git -C * log *)",
      "Bash(git status *)",
      "Bash(git -C * status *)",
      "Bash(git diff *)",
      "Bash(git -C * diff *)",
      "Bash(git show *)",
      "Bash(git -C * show *)",
      "Bash(tmux list-*)",
      "Bash(tmux show-*)",
      "Bash(tmux display-message *)",
      "Bash(tmux capture-pane *)",
      "Bash(tmux info *)"
    ],
    "ask": [],
    "defaultMode": "dontAsk"
  },
  "model": "opus",
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
